{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Labour Market Indicators by State: March 2026",
  "width": 800,
  "height": 350,

  "data": {
    "url": "ABS-March2026-Trend-long.csv"
  },

  "params": [
    {
      "name": "metric",
      "value": "Employment to population ratio",
      "bind": {
        "input": "select",
        "options": [
          "Employment to population ratio",
          "Unemployment rate",
          "Underemployment rate",
          "Participation rate"
        ],
      "labels": ["Employment Rate",
                  "Unemployment Rate",
                  "Underemployment Rate",
                  "Labor Force Participation Rate"],
        "name": "Metric: "
      }
    }
  ],

  "transform": [
    {
      "filter": "datum['March 2026 - Trend'] === metric"
    }
  ],

  "mark": {
    "type": "bar"
  },

  "encoding": {
    "x": {
      "field": "State",
      "type": "nominal",
      "sort": ["New South Wales", "Victoria", "Queensland", "Western Australia", "South Australia", "Tasmania", "Australian Capital Territory", "Northern Territory"],
      "axis": {
        "labelAngle": -45
      }
    },

    "y": {
      "field": "Value",
      "type": "quantitative",
      "title": "Percentage (%)",
      "scale": {"domain": [0,80]}
    },

    "color": {
      "field": "State",
      "type": "nominal",
      "legend": null
    },
    
    "tooltip": [
      { "field": "State", "type": "nominal" },
      { "field": "Value", "type": "quantitative" }
    ]
  }
}
