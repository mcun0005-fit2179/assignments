{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"title": "Unemployment Rates Around the World",
"width": 800,
"height": 400,
"projection": {"type": "equalEarth"},
"params": [
  {
    "name": "year",
    "value": 2025,
    "bind": {"input": "range", "min": 1991, "max": 2025, "step": 1, "name": "Year: "}
  }
],
"layer": [
  {
    "data": {
      "url": "ne_110m_admin_0_countries.json",
      "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
    },
    "mark": {"type": "geoshape", "fill": "#e0e0e0", "stroke": "black", "strokeWidth": 0.3}
  },
  {
    "data": {
      "url": "unemployment-rate-map-1991-2025.csv"
    },
    "transform": [
      {"filter": "datum.Year == year"},
      {
        "lookup": "Code",
        "from": {
          "data": {
            "url": "ne_110m_admin_0_countries.json",
            "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
          },
          "key": "properties.ADM0_A3"
        },
        "as": "geo"
      },
      {
        "calculate": "toNumber(datum['Unemployment rate'])",
        "as": "rate"
      },
      {
        "filter": "isValid(datum.rate) && isFinite(datum.rate)"
      }
    ],
    "mark": {"type": "geoshape", "stroke": "black", "strokeWidth": 0.5},
    "encoding": {
      "shape": {"field": "geo", "type": "geojson"},
      "color": {
        "field": "rate",
        "type": "quantitative",
        "scale": {
          "domain": [0, 3, 5, 8, 12, 15, 25, 35],
          "range": ["#fff5f0", "#fee0d2", "#fcbba1", "#fc9272", "#fb6a4a", "#de2d26", "#67000d", "#1a0000"]
        },
        "title": "Unemployment %"
      },
      "tooltip": [
        {"field": "Entity", "type": "nominal", "title": "Country"},
        {"field": "rate", "type": "quantitative", "title": "Unemployment Rate (%)"},
        {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"}
      ]
    }
  }
]
}
