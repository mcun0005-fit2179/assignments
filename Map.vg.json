{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"title": "Unemployment Rates Around the World",
"width": 800,
"height": 400,
"projection": {"type": "equalEarth"},
"data": {
"url": "ne_110m_admin_0_countries.json",
"format": {"type": "topojson", "feature": "countries"}
},
"transform": [
  {
    "lookup": "properties.ADM0_A3",

    "from": {
      "data": {
        "url": "unemployment-rate-map-25.csv",

        "format": {
          "type": "csv"
        }
      },

      "key": "Code",

      "fields": ["Unemployment"]
    }
  },

  {
    "calculate": "toNumber(datum.Unemployment)",
    "as": "rate"
  },
  {
  "filter": "isValid(datum.rate) && isFinite(datum.rate)"
  }
],
"mark": {"type": "geoshape", "stroke": "black", "strokeWidth": 0.5},
"encoding": {
"color": {
"field": "rate",
"type": "quantitative",
"scale": {
"scheme": "reds",
"domain": [1, 35]
}
},
"tooltip": [
{"field": "properties.NAME", "type": "nominal", "title":
"Country"},
{"field": "rate", "type": "quantitative", "title": "Unemployment Rate"}
]
}
}
